// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SurveyResponse {
  id        String   @id @default(cuid())
  sessionId String   @unique

  name   String?
  age    Int?
  gender String?

  completed Boolean  @default(false)

  inattentiveScore      Int?
  inattentivePercentage Int?
  inattentiveSeverity   String?

  hyperactiveScore      Int?
  hyperactivePercentage Int?
  hyperactiveSeverity   String?

  unofficialScore      Int?
  unofficialPercentage Int?
  unofficialSeverity   String?

  totalScore      Int?
  totalPercentage Int?
  overallSeverity String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  answers   Answer[]
}

model Answer {
  id             String        @id @default(cuid())
  surveyId       String
  symptomId      String
  category       String
  frequency      String
  impactAreas    String
  duration       String
  survey         SurveyResponse @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@unique([surveyId, symptomId])
}
